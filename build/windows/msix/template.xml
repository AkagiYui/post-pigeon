<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="PostPigeon"
        Arguments=""
        InstallLocation="C:\Program Files\AkagiYui\PostPigeon">
    </Installer>
    <PackageInformation
        PackageName="PostPigeon"
        PackageDisplayName="PostPigeon"
        PublisherName="CN=AkagiYui"
        PublisherDisplayName="AkagiYui"
        Version="0.1.0.0"
        PackageDescription="A PostPigeon application">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.akagiyui.postpigeon"
                Description="A PostPigeon application"
                DisplayName="PostPigeon"
                ExecutableName="PostPigeon"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>PostPigeon</DisplayName>
            <PublisherDisplayName>AkagiYui</PublisherDisplayName>
            <Description>A PostPigeon application</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="PostPigeon.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
