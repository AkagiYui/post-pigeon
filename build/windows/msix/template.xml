<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="post-pigeon"
        Arguments=""
        InstallLocation="C:\Program Files\AkagiYui\Post Pigeon">
    </Installer>
    <PackageInformation
        PackageName="Post Pigeon"
        PackageDisplayName="Post Pigeon"
        PublisherName="CN=AkagiYui"
        PublisherDisplayName="AkagiYui"
        Version="0.1.0.0"
        PackageDescription="A post-pigeon application">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.akagiyui.post-pigeon"
                Description="A post-pigeon application"
                DisplayName="Post Pigeon"
                ExecutableName="post-pigeon"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Post Pigeon</DisplayName>
            <PublisherDisplayName>AkagiYui</PublisherDisplayName>
            <Description>A post-pigeon application</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="post-pigeon.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
