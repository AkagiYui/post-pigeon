    "csv-parse": "1.2.4",
    "iconv-lite": "0.6.3",
    "jsrsasign": "10.3.0",
    "mockjs": "1.1.0",
    "moment": "2.22.2",
    "postman-collection": "3.4.0",
    "tv4": "1.3.0",
    "xml2js": "0.4.19"
  },
  "devDependencies": {
    "esbuild": "0.27.7",
    "esbuild-plugin-polyfill-node": "^0.3.0"
  }
